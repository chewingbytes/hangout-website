---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import logo from "../../logo.png";
import {
  ArrowLeft,
  Zap,
  Users,
  Star,
  Calendar,
  MapPin,
  Clock,
  Shield,
  Hash,
  ChevronRight,
  Sparkles,
  Lock,
} from "lucide-react";

export async function getStaticPaths() {
  const communities: CollectionEntry<"communities">[] =
    await getCollection("communities");
  return communities.map((community: CollectionEntry<"communities">) => ({
    params: { slug: community.slug },
    props: { community },
  }));
}

const { community } = Astro.props as {
  community: CollectionEntry<"communities">;
};
const { Content } = await community.render();

const related = (await getCollection("communities"))
  .filter(
    (c: CollectionEntry<"communities">) =>
      c.data.category === community.data.category && c.slug !== community.slug,
  )
  .slice(0, 3);

const personalityColors = {
  INTJ: "bg-red-300",
  INTP: "bg-orange-300",
  ENTJ: "bg-amber-300",
  ENTP: "bg-yellow-300",
  INFJ: "bg-lime-300",
  INFP: "bg-green-300",
  ENFJ: "bg-emerald-300",
  ENFP: "bg-teal-300",
  ISTJ: "bg-cyan-300",
  ISFJ: "bg-sky-300",
  ESTJ: "bg-blue-300",
  ESFJ: "bg-indigo-300",
  ISTP: "bg-violet-300",
  ISFP: "bg-purple-300",
  ESTP: "bg-fuchsia-300",
  ESFP: "bg-pink-300",
};

// Sample fake events (locked behind waitlist)
const fakeEvents = [
  { day: "SAT", date: "22", month: "MAR", title: "Weekend Meetup @ Orchard", location: "Ion Orchard B2", time: "2:00 PM" },
  { day: "SUN", date: "30", month: "MAR", title: "Night Session", location: "Tampines Hub", time: "7:30 PM" },
  { day: "FRI", date: "04", month: "APR", title: "Community Hangout", location: "City Hall MRT", time: "6:00 PM" },
];

// Sample member avatars with personality types
const sampleMembers = [
  { name: "Jordan", personality: "ENFP", initial: "J" },
  { name: "Priya", personality: "INTJ", initial: "P" },
  { name: "Marcus", personality: "ESTP", initial: "M" },
  { name: "Aisha", personality: "INFJ", initial: "A" },
  { name: "Wei", personality: "ENTP", initial: "W" },
];
---

<Layout title={`${community.data.title} | Hangout!`}>
  <!-- Waitlist Modal -->
  <dialog id="waitlist-modal" class="border-4 border-black shadow-neo-xl max-w-md w-full mx-4">
    <div class="bg-neo-bg p-8 relative">
      <div class="absolute -top-4 -right-4 bg-neo-secondary border-4 border-black p-2 rotate-12 z-10">
        <Sparkles className="w-6 h-6" />
      </div>
      <button
        id="close-modal"
        class="absolute top-4 right-4 w-10 h-10 border-4 border-black bg-white flex items-center justify-center font-black text-xl hover:bg-neo-primary hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all shadow-neo"
        aria-label="Close modal"
      >✕</button>

      <div class="mb-6">
        <div class="inline-block bg-neo-primary border-2 border-black px-3 py-1 font-black text-xs uppercase tracking-widest mb-3 -rotate-1">
          Early Access
        </div>
        <h2 class="text-4xl font-black uppercase leading-none mb-2">Join The Waitlist</h2>
        <p class="font-bold text-lg">Be first in when <span class="bg-neo-secondary px-1 border border-black">{community.data.title}</span> goes live.</p>
      </div>

      <div class="bg-yellow-50 border-4 border-black p-4 mb-6">
        <div class="flex items-center gap-2 mb-1">
          <Shield className="w-5 h-5" />
          <span class="font-black uppercase text-sm">School Email Required</span>
        </div>
        <p class="font-medium text-sm">Use your official school email (e.g. <code class="bg-black text-white px-1">john@tp.edu.sg</code>). This keeps the platform student-only and safe.</p>
      </div>

      <form id="waitlist-form" class="space-y-4">
        <div>
          <label class="block font-black uppercase text-sm mb-2 tracking-wider">Your School Email</label>
          <input
            type="email"
            id="email-input"
            placeholder="yourname@school.edu.sg"
            required
            class="w-full border-4 border-black p-4 font-bold text-lg bg-white focus:bg-neo-secondary focus:outline-none focus:shadow-neo transition-all placeholder:text-black/30"
          />
          <p class="text-xs font-bold mt-1 text-black/50">Must end in .edu.sg</p>
        </div>
        <button
          type="submit"
          class="w-full bg-neo-primary border-4 border-black py-4 font-black text-xl uppercase tracking-wider hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all shadow-neo-md flex items-center justify-center gap-2"
        >
          <Zap className="w-6 h-6 fill-black" />
          Secure My Spot
        </button>
      </form>

      <div id="waitlist-success" class="hidden text-center py-8">
        <div class="text-5xl mb-4">🎉</div>
        <h3 class="text-2xl font-black uppercase mb-2">You're In!</h3>
        <p class="font-bold">We'll email you when Hangout! launches. See you there.</p>
      </div>
    </div>
  </dialog>

  <div class="min-h-screen bg-neo-bg">
    <!-- Navigation -->
    <nav class="sticky top-0 z-50 bg-neo-bg border-b-4 border-black px-4 py-3">
      <div class="max-w-7xl mx-auto flex justify-between items-center">
        <div class="flex items-center gap-4">
          <a
            href="/communities"
            class="flex items-center gap-2 font-black uppercase text-sm border-4 border-black px-3 py-2 bg-white hover:bg-black hover:text-white transition-colors shadow-neo"
          >
            <ArrowLeft className="w-4 h-4" />
            Browse
          </a>
          <a href="/" class="hidden md:flex items-center gap-1 font-black text-xl uppercase tracking-tighter">
            <img src={logo.src} alt="Hangout!" class="w-16 h-auto" />
            Hangout!
          </a>
        </div>
        <div class="hidden md:flex items-center gap-3 font-mono text-xs border-4 border-black bg-white px-3 py-2">
          <div class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></div>
          COMMUNITY / {community.data.category.toUpperCase()} / {community.slug.toUpperCase().slice(0, 12)}
        </div>
        <button
          class="open-waitlist bg-neo-secondary px-5 py-2 border-4 border-black font-black uppercase text-sm tracking-wide hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all shadow-neo flex items-center gap-2"
        >
          <Zap className="w-4 h-4 fill-black" />
          Join Waitlist
        </button>
      </div>
    </nav>

    <main class="max-w-7xl mx-auto px-4 py-8 lg:py-12">

      <!-- Hero Banner -->
      <div class="relative mb-8 border-4 border-black overflow-hidden shadow-neo-lg">
        <div class={`h-48 md:h-64 ${community.data.color || 'bg-neo-muted'} flex items-center justify-center relative`}>
          <!-- Dot pattern overlay -->
          <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(#000 1.5px, transparent 1.5px); background-size: 20px 20px;"></div>
          <div class="relative z-10 text-center">
            <div class="text-8xl md:text-9xl mb-4 select-none">{community.data.icon}</div>
          </div>
          <!-- Vibe badge -->
          <div class="absolute top-4 left-4 bg-black text-white border-2 border-white px-3 py-1 font-black text-xs uppercase tracking-widest rotate-[-2deg]">
            VIBE: {community.data.vibe}
          </div>
          <!-- Category badge -->
          <div class="absolute top-4 right-4 bg-neo-secondary border-4 border-black px-4 py-2 font-black text-sm uppercase shadow-neo rotate-[2deg]">
            {community.data.category}
          </div>
          <!-- Verified stamp -->
          <div class="absolute bottom-4 right-4 border-4 border-black bg-white px-3 py-1 flex items-center gap-2 shadow-neo -rotate-3">
            <Shield className="w-4 h-4 text-green-600" />
            <span class="font-black text-xs text-green-700 uppercase">Student Verified</span>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">

        <!-- Sidebar -->
        <aside class="lg:col-span-4 space-y-6">

          <!-- Main Info Card -->
          <div class="bg-white border-4 border-black p-6 shadow-neo-md relative">
            <div class="absolute -top-3 -right-3 bg-neo-secondary border-4 border-black p-1 font-black text-xs uppercase rotate-12 shadow-neo">
              VERIFIED
            </div>
            <h1 class="text-3xl font-black uppercase leading-tight mb-1">{community.data.title}</h1>
            <p class="font-bold text-black/70 mb-6 border-l-4 border-black pl-3">{community.data.description}</p>

            <div class="space-y-3 font-mono text-sm border-t-4 border-black pt-4">
              <div class="flex justify-between items-center">
                <span class="font-black uppercase text-xs tracking-wider">Members</span>
                <span class="font-bold bg-neo-secondary border-2 border-black px-2">{community.data.memberCount}</span>
              </div>
              <div class="flex justify-between items-center">
                <span class="font-black uppercase text-xs tracking-wider">Vibe</span>
                <span class="font-bold bg-neo-primary border-2 border-black px-2">{community.data.vibe}</span>
              </div>
              <div class="flex justify-between items-center">
                <span class="font-black uppercase text-xs tracking-wider">Category</span>
                <span class="font-bold bg-neo-muted border-2 border-black px-2">{community.data.category}</span>
              </div>
            </div>

            <button
              class="open-waitlist mt-6 w-full bg-neo-primary border-4 border-black py-4 font-black text-lg uppercase tracking-wide hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all shadow-neo-md flex items-center justify-center gap-2"
            >
              <Zap className="w-5 h-5 fill-black" />
              Join Community
            </button>
          </div>

          <!-- Members Preview -->
          <div class="bg-neo-muted border-4 border-black p-6 shadow-neo-md">
            <h3 class="font-black uppercase text-sm tracking-widest mb-4 flex items-center gap-2">
              <Users className="w-5 h-5" /> Who's Joining
            </h3>
            <div class="space-y-3">
              {sampleMembers.map((member) => (
                <div class="flex items-center gap-3 bg-white border-2 border-black p-2">
                  <div class={`w-10 h-10 ${personalityColors[member.personality]} border-2 border-black flex items-center justify-center font-black text-sm`}>
                    {member.initial}
                  </div>
                  <div class="flex-1">
                    <div class="font-black text-sm">{member.name}</div>
                  </div>
                  <div class={`px-2 py-0.5 border border-black font-mono text-xs ${personalityColors[member.personality]} text-black`}>{member.personality}</div>
                </div>
              ))}
            </div>
            <p class="text-xs font-bold mt-3 text-black/50 text-center">+{community.data.memberCount} waiting for launch</p>
          </div>

          <!-- Tags -->
          <div class="bg-black text-white p-6 border-4 border-black shadow-neo-md">
            <h3 class="font-black mb-4 uppercase tracking-widest text-xs border-b border-gray-700 pb-2">
              Tags
            </h3>
            <div class="flex flex-wrap gap-2">
              {community.data.tags.map((tag: string) => (
                <span class="bg-gray-800 hover:bg-neo-primary hover:text-black border border-gray-600 px-2 py-1 text-xs font-mono transition-colors cursor-pointer">
                  <Hash className="w-3 h-3 inline" />{tag}
                </span>
              ))}
            </div>
          </div>

        </aside>

        <!-- Main Content -->
        <article class="lg:col-span-8 space-y-8">

          <!-- Community Story -->
          <div class="bg-white border-4 border-black p-8 shadow-neo-md relative">
            <div class="absolute -top-3 -left-3 w-6 h-6 bg-neo-primary border-2 border-black rotate-45"></div>
            <div class="bg-neo-secondary border-l-8 border-black p-4 mb-6 flex items-start gap-3">
              <span class="text-2xl">📢</span>
              <div>
                <div class="font-black uppercase text-xs tracking-widest mb-1">Community Story</div>
                <p class="font-bold">Written by community moderators. All members are Singapore students.</p>
              </div>
            </div>
            <div class="prose prose-lg max-w-none font-bold leading-relaxed">
              <Content />
            </div>
          </div>

          <!-- Upcoming Events (Locked) -->
          <div class="border-4 border-black shadow-neo-md overflow-hidden">
            <div class="bg-black text-white px-6 py-4 flex items-center justify-between">
              <h2 class="text-2xl font-black uppercase flex items-center gap-3">
                <Calendar className="w-6 h-6" /> Upcoming Hangouts
              </h2>
              <div class="flex items-center gap-2 bg-neo-primary border-2 border-white px-3 py-1">
                <Lock className="w-4 h-4" />
                <span class="font-black text-xs uppercase">Locked</span>
              </div>
            </div>

            <div class="relative">
              <!-- Blurred events -->
              <div class="blur-sm select-none pointer-events-none bg-neo-bg">
                {fakeEvents.map((ev) => (
                  <div class="flex items-center gap-4 border-b-4 border-black p-4 bg-white">
                    <div class="bg-black text-white text-center p-3 min-w-[64px] border-2 border-black">
                      <div class="text-xs font-bold uppercase">{ev.month}</div>
                      <div class="text-3xl font-black leading-none">{ev.date}</div>
                      <div class="text-xs">{ev.day}</div>
                    </div>
                    <div class="flex-1">
                      <div class="font-black text-lg uppercase">{ev.title}</div>
                      <div class="flex items-center gap-4 mt-1 text-sm font-bold text-black/60">
                        <span class="flex items-center gap-1"><MapPin className="w-3 h-3" />{ev.location}</span>
                        <span class="flex items-center gap-1"><Clock className="w-3 h-3" />{ev.time}</span>
                      </div>
                    </div>
                    <div class="bg-neo-secondary border-2 border-black px-3 py-1 font-black text-xs uppercase">Join</div>
                  </div>
                ))}
              </div>

              <!-- Overlay CTA -->
              <div class="absolute inset-0 flex items-center justify-center bg-black/10">
                <div class="bg-neo-bg border-4 border-black p-8 shadow-neo-xl text-center max-w-sm rotate-[1deg] mx-4">
                  <div class="text-4xl mb-3">🚀</div>
                  <h3 class="text-2xl font-black uppercase mb-2">Events Unlock at Launch</h3>
                  <p class="font-bold mb-4">Join the waitlist to get notified the moment we go live — and grab your spot at the first events.</p>
                  <button
                    class="open-waitlist w-full bg-neo-primary border-4 border-black py-3 font-black uppercase tracking-wide hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all shadow-neo-md flex items-center justify-center gap-2"
                  >
                    <Zap className="w-5 h-5 fill-black" />
                    Join Waitlist
                  </button>
                </div>
              </div>
            </div>
          </div>

        </article>
      </div>

      <!-- Related Communities -->
      {related.length > 0 && (
        <section class="mt-16">
          <div class="flex items-center gap-4 mb-8">
            <h2 class="text-4xl font-black uppercase">Similar Vibes</h2>
            <div class="flex-1 h-1 bg-black"></div>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {related.map((rel: CollectionEntry<"communities">) => (
              <a
                href={`/communities/${rel.slug}`}
                class="group bg-white border-4 border-black p-6 hover:-translate-y-2 hover:shadow-neo-lg transition-all duration-200 shadow-neo-md flex flex-col gap-3"
              >
                <div class="flex items-center justify-between">
                  <div class="text-4xl">{rel.data.icon}</div>
                  <span class={`${rel.data.color} border-2 border-black px-2 py-1 text-xs font-black uppercase`}>{rel.data.category}</span>
                </div>
                <h3 class="text-xl font-black uppercase leading-tight group-hover:underline decoration-4 decoration-neo-primary underline-offset-2">{rel.data.title}</h3>
                <p class="text-sm font-bold text-black/60 line-clamp-2">{rel.data.description}</p>
                <div class="flex items-center gap-2 mt-auto pt-3 border-t-2 border-black font-black text-sm uppercase">
                  View Community <ChevronRight className="w-4 h-4 group-hover:translate-x-1 transition-transform" />
                </div>
              </a>
            ))}
          </div>
        </section>
      )}

    </main>
  </div>
</Layout>

<script>
  // Open modal
  const openBtns = document.querySelectorAll(".open-waitlist");
  const modal = document.getElementById("waitlist-modal") as HTMLDialogElement;
  const closeBtn = document.getElementById("close-modal");
  const form = document.getElementById("waitlist-form");
  const success = document.getElementById("waitlist-success");
  const emailInput = document.getElementById("email-input") as HTMLInputElement;

  openBtns.forEach((btn) => {
    btn.addEventListener("click", () => modal?.showModal());
  });
  closeBtn?.addEventListener("click", () => modal?.close());
  modal?.addEventListener("click", (e) => {
    if (e.target === modal) modal.close();
  });

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const email = emailInput?.value || "";
    if (!email.endsWith(".edu.sg")) {
      emailInput.style.borderColor = "#FF6B6B";
      emailInput.placeholder = "Must be a .edu.sg email!";
      emailInput.value = "";
      return;
    }
    form.classList.add("hidden");
    success?.classList.remove("hidden");
  });
</script>
