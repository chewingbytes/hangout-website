---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import logo from "../logo.png";
import {
  ShieldCheck,
  Users,
  Zap,
  Star,
  ArrowRight,
  Menu,
  Sparkles,
  Ban,
  School,
  Key,
  Calendar,
  MapPin,
  Clock,
  ChevronRight,
  Gamepad2,
  Dumbbell,
  BookOpen,
  Coffee,
  Cpu,
  Camera,
  Lock,
  X,
  CheckCircle,
} from "lucide-react";

const personalityColors = {
  INTJ: "bg-red-300",
  INTP: "bg-orange-300",
  ENTJ: "bg-amber-300",
  ENTP: "bg-yellow-300",
  INFJ: "bg-lime-300",
  INFP: "bg-green-300",
  ENFJ: "bg-emerald-300",
  ENFP: "bg-teal-300",
  ISTJ: "bg-cyan-300",
  ISFJ: "bg-sky-300",
  ESTJ: "bg-blue-300",
  ESFJ: "bg-indigo-300",
  ISTP: "bg-violet-300",
  ISFP: "bg-purple-300",
  ESTP: "bg-fuchsia-300",
  ESFP: "bg-pink-300",
};

const personalities = [
  // Analysts
  {
    type: "INTJ",
    label: "The Strategist",
    color: personalityColors.INTJ,
    desc: "Quiet achiever, long-game player",
    emoji: "🧠",
  },
  {
    type: "INTP",
    label: "The Thinker",
    color: personalityColors.INTP,
    desc: "Curious mind, loves ideas",
    emoji: "🧩",
  },
  {
    type: "ENTJ",
    label: "The Commander",
    color: personalityColors.ENTJ,
    desc: "Bold leader, big vision",
    emoji: "🦁",
  },
  {
    type: "ENTP",
    label: "The Debater",
    color: personalityColors.ENTP,
    desc: "Loves to argue (nicely)",
    emoji: "🔥",
  },

  // Diplomats
  {
    type: "INFJ",
    label: "The Advocate",
    color: personalityColors.INFJ,
    desc: "Insightful, values-driven",
    emoji: "🌙",
  },
  {
    type: "INFP",
    label: "The Mediator",
    color: personalityColors.INFP,
    desc: "Idealistic, creative heart",
    emoji: "🎭",
  },
  {
    type: "ENFJ",
    label: "The Mentor",
    color: personalityColors.ENFJ,
    desc: "Encouraging, people-first",
    emoji: "🌟",
  },
  {
    type: "ENFP",
    label: "The Connector",
    color: personalityColors.ENFP,
    desc: "Social butterfly, idea machine",
    emoji: "🦋",
  },

  // Sentinels
  {
    type: "ISTJ",
    label: "The Inspector",
    color: personalityColors.ISTJ,
    desc: "Reliable, detail-focused",
    emoji: "📘",
  },
  {
    type: "ISFJ",
    label: "The Protector",
    color: personalityColors.ISFJ,
    desc: "Caring, dependable friend",
    emoji: "🛡️",
  },
  {
    type: "ESTJ",
    label: "The Executive",
    color: personalityColors.ESTJ,
    desc: "Organizer, gets it done",
    emoji: "📌",
  },
  {
    type: "ESFJ",
    label: "The Consul",
    color: personalityColors.ESFJ,
    desc: "Warm, community-builder",
    emoji: "🤝",
  },

  // Explorers
  {
    type: "ISTP",
    label: "The Virtuoso",
    color: personalityColors.ISTP,
    desc: "Hands-on, adaptable",
    emoji: "🛠️",
  },
  {
    type: "ISFP",
    label: "The Creator",
    color: personalityColors.ISFP,
    desc: "Makes beautiful things",
    emoji: "🎨",
  },
  {
    type: "ESTP",
    label: "The Thrill-Seeker",
    color: personalityColors.ESTP,
    desc: "Action first, questions later",
    emoji: "⚡",
  },
  {
    type: "ESFP",
    label: "The Entertainer",
    color: personalityColors.ESFP,
    desc: "Playful, lives in the moment",
    emoji: "🎉",
  },
];

const categories = [
  { name: "Gaming", icon: "🎮", color: "bg-neo-secondary", count: "42 groups" },
  { name: "Sports", icon: "⚽", color: "bg-neo-primary", count: "38 groups" },
  { name: "Study", icon: "📚", color: "bg-neo-muted", count: "29 groups" },
  { name: "Hobbies", icon: "🎭", color: "bg-green-300", count: "51 groups" },
  { name: "Tech", icon: "💻", color: "bg-blue-300", count: "24 groups" },
  { name: "Chill", icon: "🧋", color: "bg-orange-200", count: "33 groups" },
];

// Sample event card members
const eventMembers = [
  { name: "John", initial: "J", personality: "ENFP", school: "NTU" },
  { name: "Alice", initial: "A", personality: "INTJ", school: "NUS" },
  { name: "Marcus", initial: "M", personality: "ESTP", school: "SP" },
  { name: "Priya", initial: "P", personality: "INFJ", school: "TP" },
];

// Coming soon communities
const comingSoonCommunities = [
  {
    name: "K-Pop Dance Crew",
    emoji: "💃",
    category: "Hobbies",
    slots: "50 slots",
  },
  {
    name: "Night Market Hunters",
    emoji: "🍜",
    category: "Chill",
    slots: "80 slots",
  },
  {
    name: "Campus Chess League",
    emoji: "♟️",
    category: "Study",
    slots: "30 slots",
  },
  {
    name: "Indie Music Jam",
    emoji: "🎸",
    category: "Hobbies",
    slots: "40 slots",
  },
  {
    name: "3D Printing Collective",
    emoji: "🖨️",
    category: "Tech",
    slots: "25 slots",
  },
  {
    name: "Late Night Supper Club",
    emoji: "🌙",
    category: "Chill",
    slots: "60 slots",
  },
];

const allCommunities = await getCollection("communities");
const randomComm1 = allCommunities.find(c => c.slug === "badminton-casuals") || allCommunities[0];
const randomComm2 = allCommunities.find(c => c.slug === "board-game-geeks") || allCommunities[1] || allCommunities[0];

---

<Layout title="Hangout! - Safe Student Communities in Singapore">
  <!-- Waitlist Modal -->
  <dialog
    id="waitlist-modal"
    class="border-4 border-black max-w-md w-full mx-4"
  >
    <div class="bg-neo-bg p-8 relative">
      <div
        class="absolute -top-5 -right-5 w-12 h-12 bg-neo-secondary border-4 border-black rotate-12 flex items-center justify-center shadow-neo"
      >
        <Sparkles className="w-6 h-6" />
      </div>
      <button
        id="close-waitlist"
        class="absolute top-4 right-4 w-10 h-10 border-4 border-black bg-white flex items-center justify-center font-black text-xl hover:bg-neo-primary hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all shadow-neo"
        aria-label="Close">✕</button
      >

      <div class="mb-6">
        <div
          class="inline-block bg-neo-primary border-2 border-black px-3 py-1 font-black text-xs uppercase tracking-widest mb-3 -rotate-1"
        >
          🇸🇬 Students Only
        </div>
        <h2 class="text-4xl font-black uppercase leading-none mb-2">
          Join the Waitlist
        </h2>
        <p class="font-bold text-lg">
          Get early access when Hangout! launches.
        </p>
      </div>

      <div class="bg-neo-secondary border-4 border-black p-4 mb-6">
        <div class="flex items-center gap-2 mb-1">
          <ShieldCheck className="w-5 h-5" />
          <span class="font-black uppercase text-sm">Use Your School Email</span
          >
        </div>
        <p class="font-medium text-sm">
          Enter your official school email (e.g. <code
            class="bg-black text-white px-1 font-mono">you@tp.edu.sg</code
          >).
        </p>
      </div>

      <form id="waitlist-form" class="space-y-4">
        <div>
          <label class="block font-black uppercase text-sm mb-2 tracking-wider"
            >School Email Address</label
          >
          <input
            type="email"
            id="waitlist-email"
            placeholder="yourname@school.edu.sg"
            required
            class="w-full border-4 border-black p-4 font-bold text-lg bg-white focus:bg-neo-secondary focus:outline-none focus:shadow-neo transition-all placeholder:text-black/30"
          />
          <p class="text-xs font-bold mt-1 text-black/50">
            Must be a .edu.sg email, no personal emails allowed
          </p>
        </div>

        <div>
          <label class="block font-black uppercase text-sm mb-2 tracking-wider"
            >What are you into? <span class="text-black/50 normal-case font-bold text-xs ml-1">(Optional)</span></label
          >
          <div class="max-h-40 overflow-y-auto border-4 border-black p-3 bg-neo-bg mb-2 [&::-webkit-scrollbar]:w-2 [&::-webkit-scrollbar-thumb]:bg-black [&::-webkit-scrollbar-track]:bg-white">
            <div class="flex flex-wrap gap-2" id="community-pills">
              <!-- Render via script or just hardcode -->
              {
                [
                  "Badminton 🏸",
                  "Bouldering 🧗",
                  "Cafe Hopping ☕",
                  "Coding & Tech 💻",
                  "Midnight Prata 🍛",
                  "PC Gaming 🎮",
                  "Mobile Gaming 📱",
                  "Board Games 🎲",
                  "Photography 📸",
                  "Thrift Shopping 👕",
                  "Running 🏃",
                  "Study Grinding 📚",
                  "Side Hustles 🚀",
                  "Anime/Cosplay 🎭",
                  "Music/Jamming 🎸",
                ].map((item) => (
                  <label class="cursor-pointer relative">
                    <input
                      type="checkbox"
                      name="communities"
                      value={item}
                      class="peer sr-only"
                    />
                    <span class="block px-3 py-1 text-sm font-bold border-2 border-black bg-neo-muted peer-checked:bg-neo-primary peer-checked:text-black peer-hover:-translate-y-0.5 peer-active:translate-y-0 transition-all select-none">
                      {item}
                    </span>
                  </label>
                ))
              }
            </div>
          </div>
          <input
            type="text"
            id="custom-community"
            placeholder="Other? Type here... (Optional)"
            class="w-full border-4 border-black p-3 font-bold text-sm bg-white focus:bg-neo-primary focus:outline-none focus:shadow-neo transition-all placeholder:text-black/30"
          />
        </div>

        <button
          type="submit"
          class="w-full bg-neo-primary border-4 border-black py-4 font-black text-xl uppercase tracking-wider hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all shadow-neo-md flex items-center justify-center gap-3"
        >
          <Zap className="w-6 h-6 fill-black" />
          Secure My Spot
        </button>
      </form>

      <div id="waitlist-success" class="hidden text-center py-6">
        <div class="text-5xl mb-4">🎉</div>
        <h3 class="text-3xl font-black uppercase mb-2">You're on the list!</h3>
        <p class="font-bold text-lg">
          We'll hit your inbox the moment we launch. Don't ghost us.
        </p>
      </div>
    </div>
  </dialog>

  <!-- Navigation -->
  <nav class="sticky top-0 z-50 bg-neo-bg border-b-4 border-black px-4 py-3">
    <div class="max-w-7xl mx-auto flex justify-between items-center">
      <a
        href="/"
        class="flex items-center gap-1 font-black uppercase tracking-tighter text-2xl"
      >
        <img src={logo.src} alt="Hangout!" class="w-20 h-auto object-contain" />
        Hangout!
      </a>

      <div class="hidden md:flex gap-6 items-center font-bold">
        <a
          href="#how-it-works"
          class="uppercase text-sm tracking-wide hover:bg-black hover:text-white hover:px-3 hover:py-1 border-2 border-transparent hover:border-black transition-all"
          >How It Works</a
        >
        <a
          href="#safety"
          class="uppercase text-sm tracking-wide hover:bg-black hover:text-white hover:px-3 hover:py-1 border-2 border-transparent hover:border-black transition-all"
          >Safety</a
        >
        <a
          href="/communities"
          class="uppercase text-sm tracking-wide hover:bg-black hover:text-white hover:px-3 hover:py-1 border-2 border-transparent hover:border-black transition-all"
          >Communities</a
        >
        <button
          class="open-waitlist bg-neo-secondary px-6 py-2 border-4 border-black font-black uppercase text-sm tracking-wide hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all shadow-neo flex items-center gap-2"
        >
          <Zap className="w-4 h-4 fill-black" />
          Join Waitlist
        </button>
      </div>

      <button
        id="mobile-menu-btn"
        class="md:hidden w-12 h-12 border-4 border-black flex items-center justify-center bg-white shadow-neo hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all"
        aria-label="Menu"
      >
        <Menu className="w-6 h-6" />
      </button>
    </div>

    <!-- Mobile Menu -->
    <div
      id="mobile-menu"
      class="md:hidden overflow-hidden transition-all duration-300 ease-in-out max-h-0 opacity-0"
    >
      <div class="border-t-4 border-black mt-3 pt-4 pb-2 flex flex-col gap-3">
        <a
          href="#how-it-works"
          class="font-black uppercase px-4 py-3 border-2 border-black bg-white hover:bg-black hover:text-white transition-colors"
          >How It Works</a
        >
        <a
          href="#safety"
          class="font-black uppercase px-4 py-3 border-2 border-black bg-white hover:bg-black hover:text-white transition-colors"
          >Safety</a
        >
        <a
          href="/communities"
          class="font-black uppercase px-4 py-3 border-2 border-black bg-white hover:bg-black hover:text-white transition-colors"
          >Communities</a
        >
        <button
          class="open-waitlist bg-neo-primary px-4 py-3 border-4 border-black font-black uppercase shadow-neo flex items-center gap-2 justify-center"
        >
          <Zap className="w-4 h-4 fill-black" /> Join Waitlist
        </button>
      </div>
    </div>
  </nav>

  <!-- HERO SECTION -->
  <header class="relative overflow-hidden border-b-4 border-black bg-neo-bg">
    <!-- Grid background -->
    <div
      class="absolute inset-0 pointer-events-none"
      style="background-image: linear-gradient(rgba(0,0,0,0.06) 1px, transparent 1px), linear-gradient(90deg, rgba(0,0,0,0.06) 1px, transparent 1px); background-size: 40px 40px;"
    >
    </div>

    <!-- Floating sticker decorations -->
    <div
      class="hidden sm:block absolute top-8 right-4 md:right-16 lg:right-24 z-20 pointer-events-none"
    >
      <div
        class="bg-neo-primary border-4 border-black p-4 rotate-12 shadow-neo-lg animate-float"
      >
        <div class="text-white font-black text-center leading-none">
          <div class="text-3xl">🛡️</div>
          <div class="text-xs uppercase mt-1 tracking-widest">No Creeps</div>
        </div>
      </div>
    </div>
    <div
      class="hidden sm:block absolute top-32 right-2 md:right-8 z-20 pointer-events-none"
    >
      <div
        class="bg-neo-secondary border-4 border-black px-3 py-2 -rotate-6 shadow-neo"
      >
        <span class="font-black text-xs uppercase tracking-widest"
          >Singpass<br />Verified ✓</span
        >
      </div>
    </div>
    <div
      class="absolute bottom-16 left-2 md:left-8 z-20 hidden 2xl:block pointer-events-none"
    >
      <div
        class="bg-neo-muted border-4 border-black p-3 rotate-3 shadow-neo animate-bounce-slow"
      >
        <span class="font-black text-xs uppercase block">SG Students</span>
        <span class="font-black text-xs uppercase block">Only!</span>
      </div>
    </div>

    <div
      class="max-w-7xl mx-auto px-4 pt-16 pb-24 grid lg:grid-cols-2 gap-16 items-center relative z-10"
    >
      <!-- Left: Text -->
      <div class="space-y-8">
        <div class="flex flex-wrap gap-3 items-center">
          <span
            class="bg-neo-secondary border-2 border-black px-3 py-1 font-black text-xs uppercase tracking-widest -rotate-1 shadow-neo inline-block"
            >🇸🇬 Singapore Students Only</span
          >
          <span
            class="bg-neo-primary border-2 border-black px-3 py-1 font-black text-xs uppercase tracking-widest rotate-1 shadow-neo inline-block text-white"
            >Beta Coming Soon</span
          >
        </div>

        <h1
          class="text-6xl md:text-8xl font-black leading-[0.85] uppercase tracking-tighter"
        >
          Your
          <span
            style="-webkit-text-stroke: 3px black; color: transparent;"
            class="select-none">Crowd</span
          >
          <span
            class="bg-neo-primary px-3 ml-2 inline-block rotate-[-1deg] shadow-neo-md"
            >Exists.</span
          ><br />
          <span class="text-3xl sm:text-4xl md:text-5xl font-black"
            >Go Find Them.</span
          >
        </h1>

        <p
          class="text-lg md:text-xl font-bold max-w-lg border-l-4 border-black pl-5 py-2 bg-white/50"
        >
          Real offline hangouts with verified Singapore students. From
          bouldering to sim-racing to 2AM prata runs, find your people across
          schools.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <button
            class="open-waitlist group bg-neo-primary border-4 border-black px-8 py-4 font-black text-xl uppercase tracking-wider hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all shadow-neo-lg flex items-center justify-center gap-3"
          >
            <Zap
              className="w-6 h-6 fill-black group-hover:scale-125 transition-transform"
            />
            Join Waitlist
          </button>
          <a
            href="/communities"
            class="group bg-white border-4 border-black px-8 py-4 font-black text-xl uppercase tracking-wider hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all shadow-neo-lg flex items-center justify-center gap-3"
          >
            Browse Communities
            <ArrowRight
              className="w-6 h-6 group-hover:translate-x-1 transition-transform"
            />
          </a>
        </div>

        <!-- Trust bar -->
        <div class="flex flex-wrap gap-4 pt-2">
          {
            [
              { icon: "✓", text: "Singpass Verified" },
              { icon: "✓", text: "Age-Gated" },
              { icon: "✓", text: "Zero Creeps Policy" },
            ].map((item) => (
              <div class="flex items-center gap-2 font-bold text-sm">
                <span class="w-6 h-6 bg-green-400 border-2 border-black flex items-center justify-center font-black text-xs">
                  {item.icon}
                </span>
                {item.text}
              </div>
            ))
          }
        </div>
      </div>

      <!-- Right: Interactive phone-like UI mockup -->
      <div class="relative hidden lg:block">
        <!-- Shadow layer -->
        <div
          class="absolute inset-0 bg-black translate-x-5 translate-y-5 border-4 border-black -z-10"
        >
        </div>

        <div
          class="bg-white border-4 border-black p-0 rotate-1 overflow-hidden"
        >
          <!-- Phone top bar -->
          <div
            class="bg-black text-white px-4 py-2 flex items-center justify-between"
          >
            <div class="flex items-center gap-2">
              <div
                class="w-3 h-3 rounded-full bg-neo-primary border border-white/50"
              >
              </div>
              <div
                class="w-3 h-3 rounded-full bg-neo-secondary border border-white/50"
              >
              </div>
              <div
                class="w-3 h-3 rounded-full bg-green-400 border border-white/50"
              >
              </div>
            </div>
            <span class="font-mono text-xs">hangout.sg — BETA</span>
            <div class="flex items-center gap-1 font-mono text-xs">
              <div class="w-2 h-2 rounded-full bg-green-400 animate-pulse">
              </div>
              LIVE
            </div>
          </div>

          <!-- App content mockup -->
          <div class="p-8 bg-neo-bg space-y-3">
            <!-- Heading -->
            <div
              class="font-black uppercase text-xs tracking-widest text-black/50"
            >
              HAPPENING NEAR YOU
            </div>

            <!-- Event card 1 -->
            <div
              class="bg-white border-4 border-black p-4 shadow-neo hover:-translate-y-1 transition-transform cursor-pointer group"
            >
              <div class="flex items-start justify-between mb-3">
                <div>
                  <div
                    class="bg-neo-secondary border-2 border-black px-2 py-0.5 font-black text-xs uppercase inline-block mb-1"
                  >
                    {randomComm1.data.icon} {randomComm1.data.category}
                  </div>
                  <h3
                    class="font-black text-lg sm:text-xl md:text-3xl uppercase leading-tight"
                  >
                    {randomComm1.data.title}
                  </h3>
                  <div
                    class="flex items-center gap-3 text-xs sm:text-md md:text-lg font-bold text-black/60 mt-1"
                  >
                    <span class="flex items-center gap-1"
                      ><MapPin className="w-3 h-3" />Islandwide</span
                    >
                    <span class="flex items-center gap-1"
                      ><Clock className="w-3 h-3" />Soon</span
                    >
                  </div>
                </div>
                <div class={`${randomComm1.data.color} border-2 border-black p-2 text-xl`}>
                  {randomComm1.data.icon}
                </div>
              </div>
              <!-- Member avatars -->
              <div class="flex items-center gap-2 pt-3 border-t-2 border-black">
                <div class="flex -space-x-2">
                  {
                    eventMembers.map((m) => (
                      <div
                        class={`w-8 h-8 ${personalityColors[m.personality]} border-2 border-black rounded-full flex items-center justify-center font-black text-xs`}
                        title={`${m.name} — ${m.personality}`}
                      >
                        {m.initial}
                      </div>
                    ))
                  }
                </div>
                <div class="flex-1">
                  <div class="font-black text-xs">
                    {eventMembers.map((m) => m.name).join(", ")} +12 going
                  </div>
                  <div class="flex gap-1 mt-0.5">
                    {
                      eventMembers
                        .slice(0, 3)
                        .map((m) => (
                          <span
                            class={`font-mono text-[9px] px-1 border border-black ${personalityColors[m.personality]} text-black`}
                          >
                            {m.personality}
                          </span>
                        ))
                    }
                  </div>
                </div>
                <div
                  class="open-waitlist bg-black text-white px-3 py-1 font-black text-xs uppercase border-2 border-black group-hover:bg-neo-primary group-hover:text-black transition-colors"
                >
                  Join
                </div>
              </div>
            </div>

            <!-- Event card 2 mini -->
            <div
              class={`${randomComm2.data.color} border-2 border-black p-3 flex items-center gap-3 hover:-translate-y-0.5 transition-transform cursor-pointer`}
            >
              <div class="text-2xl bg-white border-2 border-black w-10 h-10 flex items-center justify-center">{randomComm2.data.icon}</div>
              <div class="flex-1 overflow-hidden">
                <div class="font-black text-sm uppercase truncate">
                  {randomComm2.data.title}
                </div>
                <div class="font-bold text-xs text-black/60">
                  {randomComm2.data.memberCount} going
                </div>
              </div>
              <div class="flex -space-x-1">
                <div
                  class="w-6 h-6 bg-neo-secondary border-2 border-black rounded-full flex items-center justify-center text-[9px] font-black"
                >
                  A
